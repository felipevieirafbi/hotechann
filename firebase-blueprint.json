{
  "entities": {
    "Product": {
      "title": "Product",
      "description": "A product in the B2B catalog",
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "price": { "type": "string" },
        "sub": { "type": "string" },
        "tag": { "type": "string" },
        "color": { "type": "string" },
        "createdAt": { "type": "number" },
        "updatedAt": { "type": "number" }
      },
      "required": ["title", "price", "sub", "tag", "color"]
    },
    "Order": {
      "title": "Order",
      "description": "An order placed by a B2B customer, which becomes a Kanban card",
      "type": "object",
      "properties": {
        "client": { "type": "string" },
        "type": { "type": "string", "enum": ["E-commerce B2B", "Licitação", "Vendedor", "Representante"] },
        "value": { "type": "string" },
        "status": { "type": "string", "enum": ["lead", "cotacao", "aprovado", "entregue"] },
        "userId": { "type": "string" },
        "createdAt": { "type": "number" },
        "updatedAt": { "type": "number" }
      },
      "required": ["client", "type", "value", "status", "userId", "createdAt"]
    },
    "UserProfile": {
      "title": "User Profile",
      "description": "Profile holding roles and data",
      "type": "object",
      "properties": {
        "email": { "type": "string" },
        "name": { "type": "string" },
        "role": { "type": "string", "enum": ["admin", "customer", "sales"] }
      },
      "required": ["email", "role"]
    }
  },
  "firestore": {
    "products/{productId}": {
      "schema": "Product",
      "description": "Public read, Admin write catalog"
    },
    "orders/{orderId}": {
      "schema": "Order",
      "description": "Kanban cards and orders placed by customers"
    },
    "users/{userId}": {
      "schema": "UserProfile",
      "description": "User profiles and roles"
    }
  }
}
