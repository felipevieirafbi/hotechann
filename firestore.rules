rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // 0. Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    // Primitive Helpers
    function isValidId(id) { return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$'); }
    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }
    function isSignedIn() { return request.auth != null; }
    function isAdmin() { 
      return isSignedIn() && 
      (request.auth.token.email == 'felipe.vieira.consultoria@gmail.com'); 
    }

    // Validation Helpers
    function isValidProduct(data) {
      return data.keys().hasAll(['title', 'price', 'sub', 'tag', 'color', 'createdAt'])
        && data.title is string && data.title.size() > 0 && data.title.size() <= 100
        && data.price is string && data.price.size() > 0 && data.price.size() <= 50
        && data.sub is string && data.sub.size() <= 50
        && data.tag is string && data.tag.size() <= 50
        && data.color is string && data.color.size() <= 20
        && data.createdAt is timestamp;
    }

    function isValidOrder(data) {
      return data.keys().hasAll(['client', 'type', 'value', 'status', 'userId', 'createdAt'])
        && (!('items' in data) || data.items is list)
        && data.client is string && data.client.size() > 0 && data.client.size() <= 100
        && data.type is string && data.type in ['E-commerce B2B', 'Licitação', 'Vendedor', 'Representante']
        && data.value is string && data.value.size() > 0 && data.value.size() <= 50
        && data.status is string && data.status in ['lead', 'cotacao', 'aprovado', 'entregue']
        && data.userId is string && data.userId == request.auth.uid
        && data.createdAt is timestamp;
    }

    function isValidUser(data) {
      return data.keys().hasAll(['email', 'role'])
        && data.email is string && data.email.size() > 0 && data.email.size() <= 200
        && data.role is string && data.role in ['admin', 'customer', 'sales'];
    }

    // Collections
    match /products/{productId} {
      allow get: if true;
      allow list: if true; // Public catalog
      allow create: if isAdmin() && isValidId(productId) && isValidProduct(incoming()) && incoming().createdAt == request.time;
      allow update: if isAdmin() && isValidId(productId) && isValidProduct(incoming()) && incoming().createdAt == existing().createdAt;
      allow delete: if isAdmin();
    }

    match /orders/{orderId} {
      allow get: if isSignedIn() && (existing().userId == request.auth.uid || isAdmin());
      allow list: if isSignedIn() && (resource.data.userId == request.auth.uid || isAdmin());
      allow create: if isSignedIn() && isValidId(orderId) && isValidOrder(incoming()) && incoming().createdAt == request.time;
      allow update: if (
        isSignedIn() && isValidId(orderId) && isValidOrder(incoming()) && (
          isAdmin() ||
          (incoming().userId == existing().userId && existing().status == 'lead' && incoming().diff(existing()).affectedKeys().hasOnly(['client', 'value', 'type', 'items']))
        )
      );
      allow delete: if isAdmin();
    }

    match /users/{userId} {
      allow get: if isSignedIn() && (request.auth.uid == userId || isAdmin());
      allow list: if isAdmin();
      allow create: if isSignedIn() && request.auth.uid == userId && isValidId(userId) && isValidUser(incoming()) && (incoming().role == 'customer' || isAdmin());
      allow update: if (isAdmin() || request.auth.uid == userId) && isValidId(userId) && isValidUser(incoming()) && (incoming().role == 'customer' || isAdmin());
      allow delete: if isAdmin();
    }
  }
}
