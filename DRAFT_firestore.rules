rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // 0. Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    // Primitive Helpers
    function isValidId(id) { return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$'); }
    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }
    function isSignedIn() { return request.auth != null; }
    function isAdmin() { return isSignedIn() && exists(/databases/$(database)/documents/users/$(request.auth.uid)) && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin'; }

    // Validation Helpers
    function isValidProduct(data) {
      return data.keys().hasAll(['title', 'price', 'sub', 'tag', 'color', 'createdAt'])
        && data.title is string && data.title.size() > 0 && data.title.size() <= 100
        && data.price is string && data.price.size() > 0 && data.price.size() <= 50
        && data.sub is string && data.sub.size() <= 50
        && data.tag is string && data.tag.size() <= 50
        && data.color is string && data.color.size() <= 20
        && data.createdAt is int;
    }

    function isValidOrder(data) {
      return data.keys().hasAll(['client', 'type', 'value', 'status', 'userId', 'createdAt'])
        && data.client is string && data.client.size() > 0 && data.client.size() <= 100
        && data.type is string && data.type in ['E-commerce B2B', 'Licitação', 'Vendedor', 'Representante']
        && data.value is string && data.value.size() > 0 && data.value.size() <= 50
        && data.status is string && data.status in ['lead', 'cotacao', 'aprovado', 'entregue']
        && data.userId is string && data.userId == request.auth.uid
        && data.createdAt is int;
    }

    function isValidUser(data) {
      return data.keys().hasAll(['email', 'role'])
        && data.email is string && data.email.size() > 0 && data.email.size() <= 200
        && data.role is string && data.role in ['admin', 'customer', 'sales'];
    }

    // Collections
    match /products/{productId} {
      allow get: if true;
      allow list: if true; // Public catalog
      allow create: if isAdmin() && isValidId(productId) && isValidProduct(incoming()) && incoming().createdAt == request.time.toMillis();
      allow update: if isAdmin() && isValidId(productId) && isValidProduct(incoming()) && incoming().createdAt == existing().createdAt;
      allow delete: if isAdmin();
    }

    match /orders/{orderId} {
      allow get: if isSignedIn() && (existing().userId == request.auth.uid || isAdmin());
      allow list: if isSignedIn() && (resource.data.userId == request.auth.uid || isAdmin());
      allow create: if isSignedIn() && isValidId(orderId) && isValidOrder(incoming()) && incoming().createdAt == request.time.toMillis();
      allow update: if (
        isSignedIn() && isValidId(orderId) && isValidOrder(incoming()) && (
          isAdmin() ||
          // Customers can't change status once it's beyond lead, for example, or let's say they can only update value/type if it's a lead
          (incoming().userId == existing().userId && existing().status == 'lead' && incoming().diff(existing()).affectedKeys().hasOnly(['client', 'value', 'type']))
        )
      );
      allow delete: if isAdmin();
    }

    match /users/{userId} {
      allow get: if isSignedIn() && (request.auth.uid == userId || isAdmin());
      // Users can't see the list of all users unless Admin.
      // But wait, there is a check if resource is not used in list securely, so:
      allow list: if isAdmin();
      
      // Self registration: can only assign 'customer' role.
      allow create: if isSignedIn() && request.auth.uid == userId && isValidId(userId) && isValidUser(incoming()) && incoming().role == 'customer';
      allow update: if isAdmin() && isValidId(userId) && isValidUser(incoming());
      allow delete: if isAdmin();
    }
  }
}
