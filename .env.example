# =============================================================
# HOTECHANN SATÉLITE — Environment Variables (.env.example)
# Copie este arquivo para .env e preencha os valores reais.
# NUNCA comitar o .env final.
# =============================================================

# --- Aplicação ---
NODE_ENV=development
APP_URL=http://localhost:3000

# --- Banco de Dados (aplicação) ---
DB_USER=hotechann
DB_PASS=change_me_in_production
DB_NAME=hotechann_db
# URL consumida pelo Prisma/NestJS.
# Dentro do Docker Compose, usar host "postgres" ao invés de "localhost".
DATABASE_URL=postgresql://hotechann:change_me_in_production@localhost:5432/hotechann_db?schema=public

# --- Banco de Dados (N8N — isolado) ---
N8N_DB_USER=n8n
N8N_DB_PASS=n8n_change_me
N8N_DB_NAME=n8n

# --- Frontend (Next.js admin & web) ---
NEXT_PUBLIC_API_URL=http://localhost:3001
NEXT_PUBLIC_COMPANY_NAME=Hotechann Faz

# --- Integrações Internas ---
# Usado para autorizar chamadas privadas entre N8N → NestJS
INTERNAL_API_SECRET=generate_a_long_random_hash

# --- N8N (basic auth no painel) ---
N8N_BASIC_AUTH_USER=admin
N8N_BASIC_AUTH_PASSWORD=change_me
N8N_WEBHOOK_URL=http://localhost:5678/

# --- Gemini / Google AI Studio ---
GEMINI_API_KEY=your_gemini_api_key_here

# =============================================================
# Futuro (placeholders — descomentar quando integrar)
# =============================================================
# TECNICON_ODBC_DSN=
# TECNICON_IMPORT_PATH=/app/data/tecnicon_exports
# WHATSAPP_EVOLUTION_API_URL=
# WHATSAPP_EVOLUTION_API_KEY=
# REDIS_URL=redis://localhost:6379
# JWT_SECRET=
# SENTRY_DSN=
