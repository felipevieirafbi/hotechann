rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    match /products/{fileName} {
      allow read: if true;
      allow write: if request.auth != null && request.auth.token.email == 'felipe.vieira.consultoria@gmail.com';
    }
    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
