{
  "name": "hotechann",
  "version": "0.1.0",
  "private": true,
  "description": "Hotechann Faz - Sistema Satélite integrado ao ERP Tecnicon",
  "packageManager": "pnpm@9.12.0",
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "clean": "turbo run clean && rm -rf node_modules",
    "db:generate": "pnpm --filter @hotechann/database db:generate",
    "db:migrate": "pnpm --filter @hotechann/database db:migrate",
    "db:push": "pnpm --filter @hotechann/database db:push",
    "db:studio": "pnpm --filter @hotechann/database db:studio"
  },
  "devDependencies": {
    "turbo": "^2.3.3",
    "typescript": "^5.6.3",
    "@types/node": "^22.9.0",
    "prettier": "^3.3.3"
  },
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=9.0.0"
  }
}
