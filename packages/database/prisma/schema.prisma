// Hotechann Faz — Schema do Sistema Satélite
// Integração com ERP Tecnicon (fiscal/contábil permanece no legado)
//
// Convenções:
// - UUIDs (gen_random_uuid) para PKs de domínio
// - Decimal(18,4) para quantidades e Decimal(18,2) para valores monetários
// - tecniconRef: identificador externo vindo do ERP legado
// - Auditoria via campos createdBy/updatedBy (FK opcional para User)

generator client {
  provider = "prisma-client-js"
  output   = "../node_modules/.prisma/client"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// =============================================================
// 0. AUTH / USERS
// =============================================================

enum UserRole {
  ADMIN
  SALES_REP
  PURCHASING
  PRODUCTION
  QUALITY
  FINANCIAL
  CUSTOMER
}

model User {
  id           String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  email        String    @unique
  passwordHash String
  name         String
  role         UserRole  @default(CUSTOMER)
  active       Boolean   @default(true)
  phone        String?
  lastLoginAt  DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  customerId String?   @db.Uuid
  customer   Customer? @relation(fields: [customerId], references: [id])

  salesRepId String?   @db.Uuid
  salesRep   SalesRep? @relation(fields: [salesRepId], references: [id])

  createdProductionOrders ProductionOrder[]    @relation("ProductionOrderCreatedBy")
  qaLogs                  QualityControlLog[]  @relation("QaAnalyzedBy")
  createdSalesOrders      SalesOrder[]         @relation("SalesOrderCreatedBy")
  createdPurchaseOrders   PurchaseOrder[]      @relation("PurchaseOrderCreatedBy")

  @@index([email])
  @@index([role])
}

// =============================================================
// 1. PARTNERS (Customers, Suppliers, Sales Reps)
// =============================================================

enum PartnerType {
  PF
  PJ
}

model Customer {
  id             String      @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tecniconRef    String?     @unique
  type           PartnerType @default(PJ)
  document       String      @unique // CPF ou CNPJ
  stateRegistration String?  // IE
  legalName      String
  tradeName      String?
  email          String?
  phone          String?
  addressStreet  String?
  addressNumber  String?
  addressCity    String?
  addressState   String?
  addressZip     String?
  active         Boolean     @default(true)
  creditLimit    Decimal?    @db.Decimal(18, 2)
  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt

  salesRepId String?   @db.Uuid
  salesRep   SalesRep? @relation(fields: [salesRepId], references: [id])

  priceListId String?    @db.Uuid
  priceList   PriceList? @relation(fields: [priceListId], references: [id])

  users          User[]
  salesOrders    SalesOrder[]
  kanbanCards    KanbanCard[]

  @@index([tecniconRef])
  @@index([document])
}

model Supplier {
  id             String      @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tecniconRef    String?     @unique
  type           PartnerType @default(PJ)
  document       String      @unique
  stateRegistration String?
  legalName      String
  tradeName      String?
  email          String?
  phone          String?
  addressStreet  String?
  addressCity    String?
  addressState   String?
  leadTimeDays   Int?        // lead time médio negociado
  active         Boolean     @default(true)
  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt

  purchaseOrders   PurchaseOrder[]
  rawMaterialLots  RawMaterialLot[]

  @@index([tecniconRef])
  @@index([document])
}

model SalesRep {
  id             String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tecniconRef    String?  @unique
  name           String
  email          String?  @unique
  phone          String?
  commissionRate Decimal  @default(0) @db.Decimal(5, 2) // percentual
  active         Boolean  @default(true)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  users       User[]
  customers   Customer[]
  salesOrders SalesOrder[]
}

// =============================================================
// 2. CATALOG (Products, Units, FISPQ)
// =============================================================

enum ProductType {
  FINISHED_GOOD  // Produto Acabado (PA)
  RAW_MATERIAL   // Matéria-Prima (MP)
  PACKAGING      // Embalagem
  INTERMEDIATE   // Semi-acabado
}

enum UnitOfMeasure {
  L   // Litros
  ML  // Mililitros
  KG  // Quilos
  G   // Gramas
  UN  // Unidades
  CX  // Caixas
  PCT // Pacotes
}

model ProductCategory {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name      String   @unique
  slug      String   @unique
  parentId  String?  @db.Uuid
  parent    ProductCategory?  @relation("CategoryHierarchy", fields: [parentId], references: [id])
  children  ProductCategory[] @relation("CategoryHierarchy")
  products  Product[]
  createdAt DateTime @default(now())
}

model Product {
  id             String      @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tecniconRef    String?     @unique
  sku            String      @unique
  barcode        String?     @unique
  name           String
  description    String?
  type           ProductType
  unit           UnitOfMeasure @default(L)
  weightKg       Decimal?    @db.Decimal(10, 4)
  densityKgPerL  Decimal?    @db.Decimal(10, 4)
  anvisaReg      String?     // registro ANVISA / notificação
  anvisaExpiry   DateTime?
  minStock       Decimal     @default(0) @db.Decimal(18, 4)
  unitCost       Decimal?    @db.Decimal(18, 4) // custo médio calculado
  basePrice      Decimal?    @db.Decimal(18, 2) // preço tabela referência
  active         Boolean     @default(true)
  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt

  categoryId String?          @db.Uuid
  category   ProductCategory? @relation(fields: [categoryId], references: [id])

  formulasAsOutput BomFormula[]     @relation("FinishedGood")
  itemsAsComponent BomItem[]        @relation("RawMaterial")
  substitutes      BomSubstitution[] @relation("SubstituteMaterial")
  stockMovements   StockMovement[]
  stockBalances    StockBalance[]
  rawMaterialLots  RawMaterialLot[]
  fispqs           Fispq[]
  priceListItems   PriceListItem[]
  salesOrderItems  SalesOrderItem[]
  purchaseOrderItems PurchaseOrderItem[]

  @@index([type])
  @@index([sku])
  @@index([tecniconRef])
}

model Fispq {
  id          String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  productId   String   @db.Uuid
  version     String   // Ex: "2024.1"
  fileUrl     String   // caminho no storage
  effectiveAt DateTime
  supersededAt DateTime?
  active      Boolean  @default(true)
  createdAt   DateTime @default(now())

  product Product @relation(fields: [productId], references: [id])

  @@unique([productId, version])
  @@index([productId, active])
}

// =============================================================
// 3. PRICING
// =============================================================

model PriceList {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name      String   @unique
  currency  String   @default("BRL")
  active    Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  items     PriceListItem[]
  customers Customer[]
}

model PriceListItem {
  id          String  @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  priceListId String  @db.Uuid
  productId   String  @db.Uuid
  price       Decimal @db.Decimal(18, 2)
  minQty      Decimal @default(1) @db.Decimal(18, 4)

  priceList PriceList @relation(fields: [priceListId], references: [id], onDelete: Cascade)
  product   Product   @relation(fields: [productId], references: [id])

  @@unique([priceListId, productId, minQty])
}

// =============================================================
// 4. ENGINEERING — Bill of Materials
// =============================================================

model BomFormula {
  id            String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  productId     String   @db.Uuid
  version       String   @default("1.0")
  baseYieldQty  Decimal  @db.Decimal(18, 4) // ex: rende 1000 L
  isActive      Boolean  @default(true)
  notes         String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  product Product           @relation("FinishedGood", fields: [productId], references: [id])
  items   BomItem[]
  orders  ProductionOrder[]

  @@unique([productId, version])
  @@index([productId, isActive])
}

model BomItem {
  id            String  @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  bomId         String  @db.Uuid
  rawMaterialId String  @db.Uuid
  requiredQty   Decimal @db.Decimal(18, 4)
  tolerancePct  Decimal @default(0) @db.Decimal(5, 2) // ± variação aceitável
  notes         String?

  bomFormula    BomFormula        @relation(fields: [bomId], references: [id], onDelete: Cascade)
  rawMaterial   Product           @relation("RawMaterial", fields: [rawMaterialId], references: [id])
  substitutions BomSubstitution[]
}

model BomSubstitution {
  id                   String  @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  bomItemId            String  @db.Uuid
  substituteMaterialId String  @db.Uuid
  conversionFactor     Decimal @default(1.0) @db.Decimal(10, 4) // ex: 1.2x
  aiPreferenceScore    Int     @default(50) // 0-100, feedback humano pra IA
  notes                String?

  bomItem            BomItem @relation(fields: [bomItemId], references: [id], onDelete: Cascade)
  substituteMaterial Product @relation("SubstituteMaterial", fields: [substituteMaterialId], references: [id])

  @@unique([bomItemId, substituteMaterialId])
}

// =============================================================
// 5. INVENTORY
// =============================================================

enum WarehouseType {
  RAW_MATERIAL
  QUARANTINE
  FINISHED_GOOD
  PACKAGING
  REJECTED
}

model Warehouse {
  id       String        @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  code     String        @unique
  name     String
  type     WarehouseType
  active   Boolean       @default(true)

  stockMovements  StockMovement[]
  stockBalances   StockBalance[]
  rawMaterialLots RawMaterialLot[]
}

enum MovementType {
  IN_PURCHASE
  IN_PRODUCTION
  IN_ADJUSTMENT
  IN_TRANSFER
  OUT_PRODUCTION
  OUT_SALE
  OUT_ADJUSTMENT
  OUT_TRANSFER
  OUT_DISPOSAL
}

model StockMovement {
  id          String       @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  productId   String       @db.Uuid
  warehouseId String       @db.Uuid
  type        MovementType
  quantity    Decimal      @db.Decimal(18, 4) // positivo; sinal vem do type
  unitCost    Decimal?     @db.Decimal(18, 4)
  rawLotId    String?      @db.Uuid
  documentRef String?      // referência cruzada (OP/OC/Tecnicon)
  reason      String?
  createdAt   DateTime     @default(now())

  product        Product         @relation(fields: [productId], references: [id])
  warehouse      Warehouse       @relation(fields: [warehouseId], references: [id])
  rawMaterialLot RawMaterialLot? @relation(fields: [rawLotId], references: [id])

  @@index([productId, warehouseId])
  @@index([rawLotId])
  @@index([createdAt])
}

// Saldo agregado pra evitar SUM() em toda tela — atualizado pela API
model StockBalance {
  id          String  @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  productId   String  @db.Uuid
  warehouseId String  @db.Uuid
  quantity    Decimal @default(0) @db.Decimal(18, 4)
  updatedAt   DateTime @updatedAt

  product   Product   @relation(fields: [productId], references: [id])
  warehouse Warehouse @relation(fields: [warehouseId], references: [id])

  @@unique([productId, warehouseId])
}

// Rastreabilidade real do lote de MP (tabela, não JSON)
model RawMaterialLot {
  id           String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  productId    String    @db.Uuid
  supplierId   String?   @db.Uuid
  warehouseId  String    @db.Uuid
  lotCode      String    // fornecedor/rótulo
  invoiceRef   String?   // NF de entrada
  receivedAt   DateTime  @default(now())
  expiresAt    DateTime?
  quantityInit Decimal   @db.Decimal(18, 4)

  product        Product         @relation(fields: [productId], references: [id])
  supplier       Supplier?       @relation(fields: [supplierId], references: [id])
  warehouse      Warehouse       @relation(fields: [warehouseId], references: [id])
  movements      StockMovement[]
  consumedByLots ProductionLotComponent[]

  @@unique([productId, lotCode])
  @@index([expiresAt])
}

// =============================================================
// 6. PRODUCTION (MRP + OP + Rastreabilidade + QA)
// =============================================================

enum OrderStatus {
  PLANNED
  RELEASED
  IN_PROGRESS
  AWAITING_QA
  COMPLETED
  CANCELED
}

model ProductionOrder {
  id          String      @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  code        String      @unique // ex: OP-2026-0001
  bomId       String      @db.Uuid
  status      OrderStatus @default(PLANNED)
  plannedQty  Decimal     @db.Decimal(18, 4)
  actualQty   Decimal?    @db.Decimal(18, 4)
  plannedDate DateTime?
  startedAt   DateTime?
  finishedAt  DateTime?
  aiGenerated Boolean     @default(false) // gerado pelo motor MRP
  aiRationale String?     // explicação da IA
  createdById String?     @db.Uuid
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  bomFormula BomFormula      @relation(fields: [bomId], references: [id])
  createdBy  User?           @relation("ProductionOrderCreatedBy", fields: [createdById], references: [id])
  lots       ProductionLot[]

  @@index([status])
  @@index([plannedDate])
}

model ProductionLot {
  id                String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  productionOrderId String   @db.Uuid
  finalLotCode      String   @unique // ex: HT-2604-001
  manufacturedDate  DateTime @default(now())
  expiresAt         DateTime?
  quantityProduced  Decimal  @db.Decimal(18, 4)

  order      ProductionOrder          @relation(fields: [productionOrderId], references: [id])
  components ProductionLotComponent[]
  qaLogs     QualityControlLog[]
}

// Cruzamento lote-pai (PA) ↔ lote-filho (MP consumida)
model ProductionLotComponent {
  id                String  @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  productionLotId   String  @db.Uuid
  rawMaterialLotId  String  @db.Uuid
  quantityConsumed  Decimal @db.Decimal(18, 4)
  substitutedForId  String? @db.Uuid // se foi substituição, aponta para o BomItem original

  productionLot ProductionLot  @relation(fields: [productionLotId], references: [id], onDelete: Cascade)
  rawLot        RawMaterialLot @relation(fields: [rawMaterialLotId], references: [id])

  @@index([productionLotId])
  @@index([rawMaterialLotId])
}

enum QaStatus {
  QUARANTINE
  APPROVED
  REJECTED
  REPROCESSING
}

model QualityControlLog {
  id              String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  productionLotId String   @db.Uuid
  status          QaStatus @default(QUARANTINE)
  phValue         Decimal? @db.Decimal(6, 2)
  viscosityCp     Decimal? @db.Decimal(10, 2)
  color           String?
  odor            String?
  aspect          String?
  additionalData  Json?    // aferições customizadas
  notes           String?
  analyzedById    String?  @db.Uuid
  analyzedAt      DateTime?
  createdAt       DateTime @default(now())

  lot        ProductionLot @relation(fields: [productionLotId], references: [id])
  analyzedBy User?         @relation("QaAnalyzedBy", fields: [analyzedById], references: [id])

  @@index([status])
}

// =============================================================
// 7. SALES (Pedidos de Venda)
// =============================================================

enum SalesChannel {
  ECOMMERCE
  REPRESENTATIVE
  BIDDING      // licitação / pregão
  INTERNAL
}

enum SalesOrderStatus {
  DRAFT
  CONFIRMED
  SENT_TO_ERP    // enviado ao Tecnicon para faturamento
  INVOICED
  DELIVERED
  CANCELED
}

model SalesOrder {
  id             String           @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  code           String           @unique
  tecniconRef    String?          @unique
  customerId     String           @db.Uuid
  salesRepId     String?          @db.Uuid
  channel        SalesChannel
  status         SalesOrderStatus @default(DRAFT)
  totalAmount    Decimal          @default(0) @db.Decimal(18, 2)
  notes          String?
  expectedDate   DateTime?
  createdById    String?          @db.Uuid
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt

  customer  Customer  @relation(fields: [customerId], references: [id])
  salesRep  SalesRep? @relation(fields: [salesRepId], references: [id])
  createdBy User?     @relation("SalesOrderCreatedBy", fields: [createdById], references: [id])
  items     SalesOrderItem[]
  kanbanCards KanbanCard[]

  @@index([customerId])
  @@index([status])
  @@index([channel])
}

model SalesOrderItem {
  id            String  @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  salesOrderId  String  @db.Uuid
  productId     String  @db.Uuid
  quantity      Decimal @db.Decimal(18, 4)
  unitPrice     Decimal @db.Decimal(18, 2)
  discount      Decimal @default(0) @db.Decimal(18, 2)

  salesOrder SalesOrder @relation(fields: [salesOrderId], references: [id], onDelete: Cascade)
  product    Product    @relation(fields: [productId], references: [id])
}

// =============================================================
// 8. PURCHASING
// =============================================================

enum PurchaseOrderStatus {
  DRAFT
  SENT
  PARTIAL_RECEIVED
  RECEIVED
  CANCELED
}

model PurchaseOrder {
  id          String              @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  code        String              @unique
  tecniconRef String?             @unique
  supplierId  String              @db.Uuid
  status      PurchaseOrderStatus @default(DRAFT)
  totalAmount Decimal             @default(0) @db.Decimal(18, 2)
  expectedDate DateTime?
  aiGenerated Boolean             @default(false)
  createdById String?             @db.Uuid
  createdAt   DateTime            @default(now())
  updatedAt   DateTime            @updatedAt

  supplier  Supplier @relation(fields: [supplierId], references: [id])
  createdBy User?    @relation("PurchaseOrderCreatedBy", fields: [createdById], references: [id])
  items     PurchaseOrderItem[]

  @@index([supplierId])
  @@index([status])
}

model PurchaseOrderItem {
  id              String  @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  purchaseOrderId String  @db.Uuid
  productId       String  @db.Uuid
  quantity        Decimal @db.Decimal(18, 4)
  unitCost        Decimal @db.Decimal(18, 4)

  purchaseOrder PurchaseOrder @relation(fields: [purchaseOrderId], references: [id], onDelete: Cascade)
  product       Product       @relation(fields: [productId], references: [id])
}

// =============================================================
// 9. CRM — Kanban (funis independentes por canal)
// =============================================================

model KanbanBoard {
  id        String       @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name      String
  channel   SalesChannel @unique // um funil por canal
  active    Boolean      @default(true)
  createdAt DateTime     @default(now())

  columns KanbanColumn[]
}

model KanbanColumn {
  id       String @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  boardId  String @db.Uuid
  name     String
  position Int

  board KanbanBoard @relation(fields: [boardId], references: [id], onDelete: Cascade)
  cards KanbanCard[]

  @@unique([boardId, position])
}

model KanbanCard {
  id           String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  columnId     String   @db.Uuid
  title        String
  description  String?
  position     Int
  value        Decimal? @db.Decimal(18, 2)
  customerId   String?  @db.Uuid
  salesOrderId String?  @db.Uuid
  dueDate      DateTime?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  column     KanbanColumn @relation(fields: [columnId], references: [id], onDelete: Cascade)
  customer   Customer?    @relation(fields: [customerId], references: [id])
  salesOrder SalesOrder?  @relation(fields: [salesOrderId], references: [id])

  @@index([columnId, position])
}

// =============================================================
// 10. AUDIT LOG (genérico)
// =============================================================

model AuditLog {
  id         String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId     String?  @db.Uuid
  entity     String   // ex: "ProductionOrder"
  entityId   String   // UUID do registro afetado
  action     String   // CREATE, UPDATE, DELETE, STATUS_CHANGE
  payload    Json?
  createdAt  DateTime @default(now())

  @@index([entity, entityId])
  @@index([userId])
}
